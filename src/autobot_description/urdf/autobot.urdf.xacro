<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="autobot">
  <!-- Link base_link -->
  <link name="base_footprint" />
  <link name="base_link">
    <inertial>
      <origin xyz="-0.000645097 1.49348e-05 0.123911" rpy="0 0 0" />
      <mass value="19.3771"/>
      <inertia ixx="0.656608" ixy="-1.63412e-05" ixz="2.74753e-05" iyy="0.740294" iyz="2.27431e-05" izz="1.21202"/>
    </inertial>
    <!-- Part base_link -->
    <visual>
      <origin xyz="-0 0 0" rpy="0 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/base_link.stl" />
      </geometry>
      <material name="base_link_material">
        <color rgba="0.917647 0.917647 0.917647 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0 0 0" rpy="0 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/base_link.stl" />
      </geometry>
    </collision>
  </link>
  <!-- Joint from base_link to base_footprint -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <!-- <origin xyz="0 0 0.03" rpy="0 0 0" /> -->
  </joint>
  <!-- Link laser_frame -->
  <link name="laser_frame">
    <inertial>
      <origin xyz="-0 -0 -0.00125" rpy="0 0 0" />
      <mass value="0.00110509" />
      <inertia ixx="3.96821e-07" ixy="0" ixz="0" iyy="3.96821e-07" iyz="0" izz="7.92491e-07" />
    </inertial>
    <!-- Part laser_frame -->
    <visual>
      <origin xyz="-0 -0 0.2355" rpy="3.14159 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/laser_frame.stl" />
      </geometry>
      <material name="laser_frame_material">
        <color rgba="0 0 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0 -0 0.2355" rpy="3.14159 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/laser_frame.stl" />
      </geometry>
    </collision>
  </link>
  <!-- Joint from base_link to laser_frame -->
  <joint name="laser_frame_joint" type="fixed">
    <origin xyz="-0 -0 0.2380" rpy="0 -0 0" />
    <parent link="base_link" />
    <child link="laser_frame" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="10" />
  </joint>
  <!-- Link front_right_wheel_link -->
  <link name="front_right_wheel_link">
    <inertial>
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
      <mass value="1.13952" />
      <inertia ixx="0.00216552" ixy="9.6e-06" ixz="-0" iyy="0.00208392" iyz="0" izz="0.00377465" />
    </inertial>
    <!-- Part front_right_wheel_link -->
    <visual>
      <origin xyz="-0.21 -0.08 -0.26" rpy="-1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/front_right_wheel_link.stl" />
      </geometry>
      <material name="front_right_wheel_link_material">
        <color rgba="0.0470588 0.470588 0.435294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0.21 -0.08 -0.26" rpy="-1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/front_right_wheel_link.stl" />
      </geometry>
    </collision>
  </link>
  <!-- Joint from base_link to front_right_wheel_link -->
  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.21 -0.26 0.08" rpy="1.5708 -0 0" />
    <parent link="base_link" />
    <child link="front_right_wheel_link" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>
  <!-- Link front_left_wheel_link -->
  <link name="front_left_wheel_link">
    <inertial>
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
      <mass value="1.13952" />
      <inertia ixx="0.00216552" ixy="-9.6e-06" ixz="-0" iyy="0.00208392" iyz="-0" izz="0.00377465" />
    </inertial>
    <!-- Part front_left_wheel_link -->
    <visual>
      <origin xyz="-0.21 0.08 -0.26" rpy="1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/front_left_wheel_link.stl" />
      </geometry>
      <material name="front_left_wheel_link_material">
        <color rgba="0.0470588 0.470588 0.435294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0.21 0.08 -0.26" rpy="1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/front_left_wheel_link.stl" />
      </geometry>
    </collision>
  </link>
  <!-- Joint from base_link to front_left_wheel_link -->
  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.21 0.26 0.08" rpy="-1.5708 -0 0" />
    <parent link="base_link" />
    <child link="front_left_wheel_link" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="10" />
  </joint>
  <!-- Link back_right_wheel_link -->
  <link name="back_right_wheel_link">
    <inertial>
      <origin xyz="-0 0 -0.025" rpy="0 0 0" />
      <mass value="1.13952" />
      <inertia ixx="0.00211984" ixy="4.16292e-05" ixz="-0" iyy="0.0021296" iyz="0" izz="0.00377465" />
    </inertial>
    <!-- Part back_right_wheel_link -->
    <visual>
      <origin xyz="0.21 -0.08 -0.26" rpy="-1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/back_right_wheel_link.stl" />
      </geometry>
      <material name="back_right_wheel_link_material">
        <color rgba="0.0470588 0.470588 0.435294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.21 -0.08 -0.26" rpy="-1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/back_right_wheel_link.stl" />
      </geometry>
    </collision>
  </link>
  <!-- Joint from base_link to back_right_wheel_link -->
  <joint name="back_right_wheel_joint" type="continuous">
    <origin xyz="-0.21 -0.26 0.08" rpy="1.5708 -0 0" />
    <parent link="base_link" />
    <child link="back_right_wheel_link" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>
  <!-- Link back_left_wheel_link -->
  <link name="back_left_wheel_link">
    <inertial>
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
      <mass value="1.13952" />
      <inertia ixx="0.00211984" ixy="-4.16292e-05" ixz="-0" iyy="0.0021296" iyz="-0"
        izz="0.00377465" />
    </inertial>
    <!-- Part back_left_wheel_link -->
    <visual>
      <origin xyz="0.21 0.08 -0.26" rpy="1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/back_left_wheel_link.stl" />
      </geometry>
      <material name="back_left_wheel_link_material">
        <color rgba="0.0470588 0.470588 0.435294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.21 0.08 -0.26" rpy="1.5708 -0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/back_left_wheel_link.stl" />
      </geometry>
    </collision>
  </link>
  <!-- Joint from base_link to back_left_wheel_link -->
  <joint name="back_left_wheel_joint" type="continuous">
    <origin xyz="-0.21 0.26 0.08" rpy="-1.5708 -0 0" />
    <parent link="base_link" />
    <child link="back_left_wheel_link" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="10" />
  </joint>
  <!-- Link rgbd_camera_link -->
  <link name="rgbd_camera_link">
    <inertial>
      <origin xyz="-0 -0.000140937 -0.00297824" rpy="0 0 0" />
      <mass value="0.0151912" />
      <inertia ixx="2.51438e-06" ixy="0" ixz="0" iyy="6.58666e-06" iyz="-6.47e-09" izz="9.005e-06" />
    </inertial>
    <!-- Part rgbd_camera_link -->
    <visual>
      <origin xyz="-0.288 0 -0.17" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/rgbd_camera_link.stl" />
      </geometry>
      <material name="rgbd_camera_link_material">
        <color rgba="0.972549 0.529412 0.00392157 1" />
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="-0.288 0 -0.17" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://autobot_description/meshes/robot/rgbd_camera_link.stl" />
      </geometry>
    </collision> -->
  </link>
  <!-- Joint from base_link to rgbd_camera_link -->
  <joint name="rgbd_camera_joint" type="fixed">
    <origin xyz="0.288 0 0.17" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rgbd_camera_link" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>

  <!-- Optical frame for the camera to match standard computer vision orientation -->
  <link name="rgbd_camera_depth_optical_frame" />
  <joint name="rgbd_camera_depth_optical_joint" type="fixed">
    <origin xyz="0.05 0 0" rpy="-1.57079632679 0 -1.57079632679" />
    <parent link="rgbd_camera_link" />
    <child link="rgbd_camera_depth_optical_frame" />
  </joint>


  <!-- Laser gazebo setup -->
  <gazebo reference="laser_frame">

    <sensor name="lidar_sensor" type="gpu_lidar">
      <topic>scan</topic>
      <frame_id>laser_frame</frame_id>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.05</min>
          <max>20</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.001</stddev>
        </noise>
      </ray>
      <gz_frame_id>laser_frame</gz_frame_id>
    </sensor>
  </gazebo>



  <!-- rgbd camera plugin -->
  <gazebo reference="rgbd_camera_link">
    <sensor name="rgbd_camera" type="rgbd_camera">
      <pose>0.05 0 0 0 0 0</pose>
      <camera>
        <horizontal_fov>1.5184</horizontal_fov>
        <image>
          <width>424</width>
          <height>240</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>5</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <gz_frame_id>rgbd_camera_depth_optical_frame</gz_frame_id>
      <topic>rgbd_camera</topic>
      <update_rate>2</update_rate>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- IMU Sensor setup -->
  <xacro:include
    filename="$(find autobot_description)/urdf/sensors/imu.urdf.xacro" />
  <xacro:imu_sensor
    parent="base_link"
    frame_id="imu"
    xyz_offset="0 0 0"
    rpy_offset="0 0 0"
    topic_name="imu/data" />

  <xacro:include
    filename="$(find autobot_description)/urdf/control/velocity_control_plugin.urdf.xacro" />
  <xacro:load_velocity_control_plugin use_gazebo="$(arg use_gazebo)" />

  <xacro:include
    filename="$(find autobot_description)/urdf/control/gazebo_sim_ros2_control.urdf.xacro" />
  <xacro:load_gazebo_sim_ros2_control_plugin
    robot_name="$(arg robot_name)"
    use_gazebo="$(arg use_gazebo)" />

  <xacro:include
    filename="$(find autobot_description)/urdf/control/autobot_ros2_control.urdf.xacro" />
  <xacro:autobot_ros2_control
    use_gazebo="$(arg use_gazebo)" />

</robot>